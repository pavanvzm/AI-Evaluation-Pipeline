# AI Evaluation Pipeline - Production Environment
# Copy this file to .env and configure for production

# =============================================================================
# API Keys - REQUIRED
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key  
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Groq API Key
GROQ_API_KEY=gsk_your-groq-api-key

# =============================================================================
# Database Configuration
# =============================================================================

POSTGRES_USER=ai_eval
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
POSTGRES_DB=evaluation

# =============================================================================
# Service Ports
# =============================================================================

API_PORT=8000
DASHBOARD_PORT=8501
DB_PORT=5432
REDIS_PORT=6379

# =============================================================================
# Logging & Monitoring
# =============================================================================

LOG_LEVEL=INFO

# Prometheus metrics
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=CHANGE_ME

# =============================================================================
# Security
# =============================================================================

# Secret key for session management
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# CORS origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# =============================================================================
# Evaluation Settings
# =============================================================================

MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=120
ENABLE_CACHING=true

# Evaluator model for LLM-as-judge
EVALUATOR_MODEL=gpt-4o-mini

# Embedding model for semantic similarity
EMBEDDING_MODEL=all-MiniLM-L6-v2
# AI Evaluation Pipeline - Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# API KEYS - Required for model providers
# =============================================================================

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Groq API Key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your-groq-api-key-here

# =============================================================================
# OPTIONAL: Additional Provider API Keys
# =============================================================================

# Together AI (alternative Llama provider)
TOGETHER_API_KEY=

# Azure OpenAI (if using Azure deployment)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-01

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite (default - no configuration needed)
# DATABASE_URL=sqlite:///data/evaluation_results.db

# PostgreSQL (uncomment and configure if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/evaluation_db

# =============================================================================
# EVALUATION SETTINGS
# =============================================================================

# Maximum concurrent API requests (default: 5)
MAX_CONCURRENT_REQUESTS=5

# Request timeout in seconds (default: 60)
REQUEST_TIMEOUT=60

# Enable caching for responses (default: true)
ENABLE_CACHING=true

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/evaluation.log

# =============================================================================
# DASHBOARD SETTINGS
# =============================================================================

# Streamlit dashboard port
DASHBOARD_PORT=8501

# Enable real-time updates
REAL_TIME_UPDATES=true

# =============================================================================
# EVALUATOR MODEL (for LLM-as-a-Judge)
# =============================================================================

# Model to use for faithfulness/hallucination evaluation
# Options: gpt-4o, claude-3-5-sonnet-20240620, llama-3.1-70b-versatile
EVALUATOR_MODEL=gpt-4o-mini

# =============================================================================
# EMBEDDING MODEL
# =============================================================================

# Model for semantic similarity calculations
# Options: all-MiniLM-L6-v2 (fast), all-mpnet-base-v2 (accurate)
EMBEDDING_MODEL=all-MiniLM-L6-v2